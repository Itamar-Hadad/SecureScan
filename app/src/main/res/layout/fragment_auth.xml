<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/auth_layout_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/secure_scan_background"
    android:layoutDirection="ltr"
    tools:context=".ui.AuthFragment">

    <View
        android:id="@+id/auth_VIEW_topGradient"
        android:layout_width="0dp"
        android:layout_height="200dp"
        android:background="@drawable/qr_scan_top_gradient"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.appcompat.widget.LinearLayoutCompat
        android:id="@+id/auth_layout_topBar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="@dimen/default_margin"
        android:paddingTop="@dimen/qr_scan_header_top_padding"
        android:paddingEnd="@dimen/default_margin"
        android:paddingBottom="@dimen/default_Padding"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <androidx.appcompat.widget.AppCompatImageButton
            android:id="@+id/auth_BTN_back"
            android:layout_width="@dimen/arrow_back_size"
            android:layout_height="@dimen/arrow_back_size"
            android:background="@color/transparent"
            android:contentDescription="@string/auth_back_content_description"
            android:padding="@dimen/default_padding2"
            android:scaleType="centerInside"
            app:srcCompat="@drawable/ic_qr_scan_back" />

        <com.google.android.material.textview.MaterialTextView
            android:id="@+id/auth_LBL_title"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginStart="4dp"
            android:layout_weight="1"
            android:text="@string/auth_screen_title"
            android:textColor="@color/secure_scan_on_surface"
            android:textSize="@dimen/bar_title_size"
            android:textStyle="bold" />
    </androidx.appcompat.widget.LinearLayoutCompat>

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/auth_LBL_subtitle"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/default_margin"
        android:layout_marginTop="4dp"
        android:layout_marginEnd="@dimen/default_margin"
        android:text="@string/auth_screen_subtitle"
        android:textAlignment="viewStart"
        android:textColor="@color/secure_scan_on_surface_muted"
        android:textSize="@dimen/instruction_camera_text_size"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/auth_layout_topBar" />

    <androidx.core.widget.NestedScrollView
        android:id="@+id/auth_scroll_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="@dimen/button_margin"
        android:paddingTop="@dimen/qr_scan_section_spacing"
        android:paddingEnd="@dimen/button_margin"
        android:paddingBottom="@dimen/big_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/auth_LBL_subtitle">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/auth_CARD_form"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/secure_scan_surface_elevated"
            app:cardCornerRadius="@dimen/qr_scan_bottom_card_radius"
            app:cardElevation="6dp"
            app:strokeColor="@color/secure_scan_card_stroke"
            app:strokeWidth="1dp">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/default_padding4">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/auth_LBL_welcome"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auth_welcome_headline"
                    android:textColor="@color/secure_scan_on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/auth_LBL_emailCaption"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:text="@string/auth_email_label"
                    android:textAllCaps="true"
                    android:textColor="@color/brand_accent_pink"
                    android:textSize="11sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/auth_LBL_email"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="6dp"
                    android:background="@drawable/bg_auth_email_field"
                    android:paddingHorizontal="16dp"
                    android:paddingVertical="14dp"
                    android:textIsSelectable="true"
                    android:focusable="false"
                    android:clickable="false"
                    android:textColor="@color/secure_scan_on_surface"
                    android:textSize="16sp"
                    tools:text="user@company.com" />

                <com.google.android.material.textfield.TextInputLayout
                    android:id="@+id/auth_INP_layout_password"
                    style="@style/Widget.Material3.TextInputLayout.OutlinedBox"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="20dp"
                    android:hint="@string/auth_password_hint"
                    app:boxCornerRadiusBottomEnd="16dp"
                    app:boxCornerRadiusBottomStart="16dp"
                    app:boxCornerRadiusTopEnd="16dp"
                    app:boxCornerRadiusTopStart="16dp"
                    app:boxStrokeColor="@color/auth_input_stroke"
                    app:cursorColor="@color/brand_accent_pink"
                    app:endIconMode="password_toggle"
                    app:endIconTint="@color/brand_accent_pink"
                    app:hintTextColor="@color/secure_scan_on_surface_muted">

                    <com.google.android.material.textfield.TextInputEditText
                        android:id="@+id/auth_EDT_password"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:inputType="textPassword"
                        android:textColor="@color/secure_scan_on_surface"
                        android:textColorHint="@color/secure_scan_on_surface_muted"
                        android:textSize="16sp" />
                </com.google.android.material.textfield.TextInputLayout>

                <FrameLayout
                    android:id="@+id/auth_layout_submit"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="28dp">

                    <com.google.android.material.button.MaterialButton
                        android:id="@+id/auth_BTN_signIn"
                        style="@style/Widget.Material3.Button"
                        android:layout_width="match_parent"
                        android:layout_height="56dp"
                        android:insetTop="0dp"
                        android:insetBottom="0dp"
                        android:text="@string/auth_sign_in"
                        android:textAllCaps="false"
                        android:textSize="16sp"
                        android:textStyle="bold"
                        app:backgroundTint="@color/brand_accent_pink"
                        app:cornerRadius="16dp" />

                    <ProgressBar
                        android:id="@+id/auth_PRB_loading"
                        style="?android:attr/progressBarStyle"
                        android:layout_width="@dimen/loading_signin_circle_size"
                        android:layout_height="@dimen/loading_signin_circle_size"
                        android:layout_gravity="center"
                        android:indeterminateTint="@color/secure_scan_on_primary"
                        android:visibility="gone" />
                </FrameLayout>
            </androidx.appcompat.widget.LinearLayoutCompat>
        </com.google.android.material.card.MaterialCardView>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
