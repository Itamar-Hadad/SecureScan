<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/secure_scan_background"
    android:layoutDirection="ltr"
    tools:context=".ui.ErrorFragment">


    <androidx.core.widget.NestedScrollView
        android:id="@+id/auth_err_scroll_content"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:clipToPadding="false"
        android:fillViewport="true"
        android:overScrollMode="never"
        android:paddingStart="@dimen/button_margin"
        android:paddingTop="@dimen/qr_scan_section_spacing"
        android:paddingEnd="@dimen/button_margin"
        android:paddingBottom="@dimen/big_padding"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent">

        <com.google.android.material.card.MaterialCardView
            android:id="@+id/auth_err_CARD_content"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardBackgroundColor="@color/secure_scan_surface_elevated"
            app:cardCornerRadius="@dimen/qr_scan_bottom_card_radius"
            app:cardElevation="6dp"
            app:strokeColor="@color/secure_scan_card_stroke"
            app:strokeWidth="1dp">

            <androidx.appcompat.widget.LinearLayoutCompat
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="@dimen/default_padding4">

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/auth_err_LBL_title"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="@string/auth_error_sign_in_failed"
                    android:textAlignment="viewStart"
                    android:textColor="@color/secure_scan_on_surface"
                    android:textSize="20sp"
                    android:textStyle="bold" />

                <com.google.android.material.textview.MaterialTextView
                    android:id="@+id/auth_err_LBL_message"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginTop="@dimen/default_padding3"
                    android:textAlignment="viewStart"
                    android:textColor="@color/secure_scan_on_surface_muted"
                    android:textSize="16sp"
                    tools:text="@string/auth_error_generic" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/auth_err_BTN_retry"
                    style="@style/Widget.Material3.Button"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="28dp"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/auth_error_retry"
                    android:textAllCaps="false"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:backgroundTint="@color/brand_accent_pink"
                    app:cornerRadius="@dimen/default_margin" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/auth_err_BTN_scanQr"
                    style="@style/Widget.Material3.Button.OutlinedButton"
                    android:layout_width="match_parent"
                    android:layout_height="@dimen/button_height"
                    android:layout_marginTop="@dimen/default_padding3"
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    android:text="@string/auth_error_scan_qr_again"
                    android:textAllCaps="false"
                    android:textColor="@color/brand_accent_pink"
                    android:textSize="16sp"
                    android:textStyle="bold"
                    app:cornerRadius="@dimen/default_margin"
                    app:strokeColor="@color/brand_accent_pink"
                    app:strokeWidth="1dp" />
            </androidx.appcompat.widget.LinearLayoutCompat>
        </com.google.android.material.card.MaterialCardView>
    </androidx.core.widget.NestedScrollView>

</androidx.constraintlayout.widget.ConstraintLayout>
