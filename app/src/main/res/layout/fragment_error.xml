<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/secure_scan_background"
    android:padding="@dimen/default_margin"
    tools:context=".ui.ErrorFragment">

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/error_LBL_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/auth_error_title"
        android:textAlignment="viewStart"
        android:textColor="@color/secure_scan_on_surface"
        android:textSize="22sp"
        android:textStyle="bold"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintVertical_chainStyle="packed" />

    <com.google.android.material.textview.MaterialTextView
        android:id="@+id/error_LBL_message"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="12dp"
        android:textAlignment="viewStart"
        android:textColor="@color/secure_scan_on_surface_muted"
        android:textSize="16sp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/error_LBL_title"
        tools:text="Invalid password." />

    <com.google.android.material.button.MaterialButton
        android:id="@+id/error_BTN_tryAgain"
        style="@style/Widget.Material3.Button"
        android:layout_width="0dp"
        android:layout_height="56dp"
        android:layout_marginTop="28dp"
        android:insetTop="0dp"
        android:insetBottom="0dp"
        android:text="@string/auth_error_try_again"
        android:textAllCaps="false"
        app:backgroundTint="@color/brand_accent_pink"
        app:cornerRadius="16dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/error_LBL_message" />

</androidx.constraintlayout.widget.ConstraintLayout>
