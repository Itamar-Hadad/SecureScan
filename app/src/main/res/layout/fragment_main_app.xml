<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/secure_scan_background"
    tools:context=".ui.MainAppFragment">

    <com.google.android.material.appbar.MaterialToolbar
        android:id="@+id/main_app_toolbar"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:background="@color/secure_scan_surface_elevated"
        android:elevation="4dp"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:title="@string/main_app_title"
        app:titleCentered="true"
        app:titleTextColor="@color/secure_scan_on_surface"
        app:titleTextAppearance="@style/TextAppearance.Material3.TitleLarge" />

    <View
        android:id="@+id/main_app_top_accent"
        android:layout_width="@dimen/line_width"
        android:layout_height="@dimen/line_height"
        android:layout_marginTop="4dp"
        android:background="@color/brand_accent_pink"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/main_app_toolbar" />

    <androidx.fragment.app.FragmentContainerView
        android:id="@+id/main_app_child_container"
        android:layout_width="0dp"
        android:layout_height="0dp"
        android:layout_marginTop="@dimen/default_padding3"
        app:layout_constraintBottom_toTopOf="@id/main_app_bottom_nav_card"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@id/main_app_top_accent" />

    <com.google.android.material.card.MaterialCardView
        android:id="@+id/main_app_bottom_nav_card"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="@dimen/default_margin"
        android:layout_marginEnd="@dimen/default_margin"
        android:layout_marginBottom="@dimen/default_margin"
        app:cardBackgroundColor="@color/secure_scan_surface_elevated"
        app:cardCornerRadius="@dimen/qr_scan_frame_corner_radius"
        app:cardElevation="10dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:strokeColor="@color/secure_scan_card_stroke"
        app:strokeWidth="1dp">

        <com.google.android.material.bottomnavigation.BottomNavigationView
            android:id="@+id/main_app_bottom_nav"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@android:color/transparent"
            android:paddingStart="@dimen/default_padding2"
            android:paddingTop="@dimen/default_padding2"
            android:paddingEnd="@dimen/default_padding2"
            android:paddingBottom="@dimen/default_padding2"
            app:itemIconTint="@color/main_bottom_nav_item_colors"
            app:itemTextColor="@color/main_bottom_nav_item_colors"
            app:labelVisibilityMode="labeled"
            app:menu="@menu/main_app_bottom_nav_menu" />
    </com.google.android.material.card.MaterialCardView>

</androidx.constraintlayout.widget.ConstraintLayout>